{
  "name": "crabd-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "crab'd — a forge-agnostic, multi-provider agent harness for CI",
  "packageManager": "pnpm@11.4.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "dev:docs": "pnpm --filter @crabd/docs dev",
    "build:docs": "pnpm --filter @crabd/docs build",
    "start:docs": "pnpm --filter @crabd/docs start",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "^5.9.2"
  }
}
